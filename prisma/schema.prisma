generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================

enum UserType {
  OWNER
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AppType {
  PUBLIC
  PRIVATE
}

enum DeviceType {
  ANDROID
  IOS
  WEB
}

enum RevokeReason {
  LOGOUT
  PASSWORD_CHANGED
  ADMIN_REVOKE
}

enum DeliveryPolicy {
  OPEN
  SCHEDULED
  MANUAL
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  REPEATED
  TRANSFERRED_OUT
  DROPPED
}

enum ScopeType {
  SUPERVISE
}

enum SubjectSectionRole {
  PRIMARY
  ASSISTANT
}

enum GradeStage {
  KG
  BASIC
  SECONDARY
  OTHER
}

enum PlatformRole {
  PLATFORM_ADMIN
  PLATFORM_TEACHER
}

// =========================
// MODELS
// =========================

// المستخدمون
model User {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  schoolId  Int?    @map("school_id")
  school   School? @relation(fields: [schoolId], references: [id])

  userType    UserType @map("user_type")
  code        Int?
  name        String
  displayName String?  @map("display_name")
  gender      String?

  phone String?
  email String?

  province       String?
  district       String?
  addressArea    String? @map("address_area")
  addressDetails String? @map("address_details")

  avatarMediaAssetId Int?        @map("avatar_media_asset_id")
  avatarMediaAsset   MediaAsset? @relation("UserAvatar", fields: [avatarMediaAssetId], references: [id])

  passwordHash String @map("password_hash")

  isActive  Boolean   @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  devices        UserDevice[]
  sessions       AuthSession[]
  uploadSessions MediaUploadSession[]

  // Role-specific profile (1:1)
  student Student?
  parent  Parent?
  teacher Teacher?

  lessonTemplatesCreated LessonTemplate[]    @relation("LessonTemplateCreator")
  lessonDeliveryLogs     LessonDeliveryLog[] @relation("LessonDeliveryActor")

  @@index([schoolId], map: "users_school_id_idx")
  @@index([avatarMediaAssetId], map: "users_avatar_media_asset_id_idx")
  @@map("users")
}

// المدارس
model School {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  name        String
  displayName String?
  schoolCode  Int     @unique
  appType     AppType

  phone            String?
  email            String?
  logoMediaAssetId Int?        @map("logo_media_asset_id")
  logoMediaAsset   MediaAsset? @relation("SchoolLogo", fields: [logoMediaAssetId], references: [id])

  address       String?
  province      String?
  district      String?
  addressArea   String?
  educationType String?

  ownerNotes String?

  nextUserCode Int @default(1)

  primaryColor    String?
  secondaryColor  String?
  backgroundColor String?

  deliveryPolicy DeliveryPolicy @default(OPEN)

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  authSessions    AuthSession[]
  years           Year[]
  schoolGrades    SchoolGrade[]
  subjects        Subject[]
  mediaAssets     MediaAsset[]         @relation("SchoolMediaAssets")
  uploadSessions  MediaUploadSession[] @relation("SchoolUploadSessions")
  units           Unit[]
  lessonTemplates LessonTemplate[]
  lessons         Lesson[]
}

// قاموس الصفوف العام
model GradeDictionary {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  code        String      @unique
  defaultName String
  shortName   String?
  stage       GradeStage?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolGrades      SchoolGrade[]
  subjectDictionary SubjectDictionary[]
}

// =========================
// ACADEMIC STRUCTURE
// =========================

// السنوات الدراسية (التواريخ تُشتق من الفصول)
model Year {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  schoolId Int    @map("school_id")
  school   School @relation(fields: [schoolId], references: [id])

  name      String
  isCurrent Boolean @default(false) @map("is_current")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  terms       Term[]
  enrollments StudentEnrollment[]
  timetables  Timetable[]
  lessons     Lesson[]

  @@index([schoolId], map: "years_school_id_idx")
  @@map("years")
}

// الفصول الدراسية
model Term {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  yearId Int  @map("year_id")
  year   Year @relation(fields: [yearId], references: [id])

  name       String
  orderIndex Int       @map("order_index")
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  isCurrent  Boolean   @default(false) @map("is_current")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  timetables Timetable[]
  lessons    Lesson[]

  @@index([yearId], map: "terms_year_id_idx")
  @@map("terms")
}

// صفوف المدرسة
model SchoolGrade {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  schoolId Int    @map("school_id")
  school   School @relation(fields: [schoolId], references: [id])

  dictionaryId Int?             @map("dictionary_id")
  dictionary   GradeDictionary? @relation(fields: [dictionaryId], references: [id])

  displayName String      @map("display_name")
  shortName   String?     @map("short_name")
  sortOrder   Int         @map("sort_order")
  stage       GradeStage? @map("stage")
  isLocal     Boolean     @default(false) @map("is_local")
  isActive    Boolean     @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  sections      Section[]
  enrollments   StudentEnrollment[]
  subjects      Subject[]
  teacherScopes TeacherScope[]

  @@index([schoolId], map: "school_grades_school_id_idx")
  @@index([dictionaryId], map: "school_grades_dictionary_id_idx")
  @@map("school_grades")
}

// الشُعب
model Section {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  gradeId Int         @map("grade_id")
  grade   SchoolGrade @relation(fields: [gradeId], references: [id])

  name       String
  orderIndex Int     @map("order_index")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  enrollments     StudentEnrollment[]
  subjectSections SubjectSection[]
  teacherScopes   TeacherScope[]
  timetables      Timetable[]
  lessonTargets   LessonTarget[]

  @@index([gradeId], map: "sections_grade_id_idx")
  @@map("sections")
}

// =========================
// USER ROLE PROFILES
// =========================

// بيانات الطالب الإضافية
model Student {
  userId Int    @id @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  uuid   String @unique @default(uuid())

  birthDate DateTime? @map("birth_date") @db.Date

  enrollments    StudentEnrollment[]
  parentLinks    ParentStudent[]
  lessonProgress StudentLessonProgress[]
  lessonResults  StudentLessonResult[]
  answers        StudentAnswer[]

  @@map("students")
}

// بيانات ولي الأمر
model Parent {
  userId Int    @id @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  uuid   String @unique @default(uuid())

  childLinks ParentStudent[]

  @@map("parents")
}

// بيانات المعلم الإضافية
model Teacher {
  userId Int    @id @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  uuid   String @unique @default(uuid())

  hireDate       DateTime? @map("hire_date") @db.Date
  isSupervisor   Boolean   @default(false) @map("is_supervisor")
  specialization String?
  qualification  String?
  experience     String?
  notes          String?

  scopes                 TeacherScope[]
  extraPermissions       TeacherExtraPermission?
  subjectSectionTeachers SubjectSectionTeacher[]
  lessons                Lesson[]

  @@map("teachers")
}

// =========================
// ENROLLMENT & RELATIONSHIPS
// =========================

// قيد الطالب عبر السنوات
model StudentEnrollment {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [userId])

  yearId Int  @map("year_id")
  year   Year @relation(fields: [yearId], references: [id])

  gradeId Int         @map("grade_id")
  grade   SchoolGrade @relation(fields: [gradeId], references: [id])

  sectionId Int     @map("section_id")
  section   Section @relation(fields: [sectionId], references: [id])

  status    EnrollmentStatus @default(ACTIVE)
  isCurrent Boolean          @default(true) @map("is_current")

  joinedAt DateTime? @map("joined_at") @db.Date
  leftAt   DateTime? @map("left_at") @db.Date
  notes    String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([studentId, yearId], map: "student_enrollments_student_year_key")
  @@index([studentId, isCurrent], map: "student_enrollments_student_current_idx")
  @@index([yearId, sectionId], map: "student_enrollments_year_section_idx")
  @@index([updatedAt], map: "student_enrollments_updated_at_idx")
  @@map("student_enrollments")
}

// ربط ولي أمر بطالب
model ParentStudent {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  parentId Int    @map("parent_id")
  parent   Parent @relation(fields: [parentId], references: [userId])

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [userId])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([parentId, studentId], map: "parent_students_parent_student_key")
  @@index([parentId, isDeleted], map: "parent_students_parent_deleted_idx")
  @@map("parent_students")
}

// =========================
// TEACHER SCOPES & PERMISSIONS
// =========================

// نطاق إشراف المعلم
model TeacherScope {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  teacherId Int     @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [userId])

  gradeId Int         @map("grade_id")
  grade   SchoolGrade @relation(fields: [gradeId], references: [id])

  sectionId Int?     @map("section_id")
  section   Section? @relation(fields: [sectionId], references: [id])

  scopeType ScopeType @default(SUPERVISE) @map("scope_type")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@index([teacherId, updatedAt], map: "teacher_scopes_teacher_updated_idx")
  @@map("teacher_scopes")
}

// صلاحيات المعلم الإضافية (1:1)
model TeacherExtraPermission {
  teacherId Int     @id @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [userId])
  uuid      String  @unique @default(uuid())

  canManageSubjects  Boolean @default(false) @map("can_manage_subjects")
  canManageTimetable Boolean @default(false) @map("can_manage_timetable")
  canManageStudents  Boolean @default(false) @map("can_manage_students")
  canManageParents   Boolean @default(false) @map("can_manage_parents")
  canViewReports     Boolean @default(false) @map("can_view_reports")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@map("teacher_extra_permissions")
}

// =========================
// SUBJECTS & ASSIGNMENT
// =========================

// قاموس المواد الرسمي
model SubjectDictionary {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  gradeDictionaryId Int             @map("grade_dictionary_id")
  gradeDictionary   GradeDictionary @relation(fields: [gradeDictionaryId], references: [id])

  code        String? @unique
  defaultName String  @map("default_name")
  shortName   String? @map("short_name")
  sortOrder   Int     @default(0) @map("sort_order")

  isActive          Boolean     @default(true) @map("is_active")
  coverMediaAssetId Int?        @map("cover_media_asset_id")
  coverMediaAsset   MediaAsset? @relation("SubjectDictCover", fields: [coverMediaAssetId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  subjects             Subject[]
  platformUserSubjects PlatformUserSubject[]
  units                Unit[]
  lessonTemplates      LessonTemplate[]

  @@index([gradeDictionaryId, sortOrder], map: "subject_dictionary_grade_sort_idx")
  @@map("subject_dictionary")
}

// مواد المدرسة
model Subject {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  schoolId Int    @map("school_id")
  school   School @relation(fields: [schoolId], references: [id])

  gradeId Int         @map("grade_id")
  grade   SchoolGrade @relation(fields: [gradeId], references: [id])

  dictionaryId Int?               @map("dictionary_id")
  dictionary   SubjectDictionary? @relation(fields: [dictionaryId], references: [id])

  displayName       String      @map("display_name")
  shortName         String?     @map("short_name")
  coverMediaAssetId Int?        @map("cover_media_asset_id")
  coverMediaAsset   MediaAsset? @relation("SubjectCover", fields: [coverMediaAssetId], references: [id])

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  subjectSections SubjectSection[]
  units           Unit[]
  lessonTemplates LessonTemplate[]
  lessons         Lesson[]

  @@index([schoolId, gradeId], map: "subjects_school_grade_idx")
  @@index([dictionaryId], map: "subjects_dictionary_id_idx")
  @@map("subjects")
}

// تقديم المادة داخل الشعبة
model SubjectSection {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  subjectId Int     @map("subject_id")
  subject   Subject @relation(fields: [subjectId], references: [id])

  sectionId Int     @map("section_id")
  section   Section @relation(fields: [sectionId], references: [id])

  isActive Boolean @default(true) @map("is_active")
  notes    String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  teachers       SubjectSectionTeacher[]
  timetableSlots TimetableSlot[]

  @@unique([subjectId, sectionId], map: "subject_sections_subject_section_key")
  @@index([updatedAt], map: "subject_sections_updated_at_idx")
  @@map("subject_sections")
}

// إسناد المعلم للمادة داخل شعبة
model SubjectSectionTeacher {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  subjectSectionId Int            @map("subject_section_id")
  subjectSection   SubjectSection @relation(fields: [subjectSectionId], references: [id])

  teacherId Int     @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [userId])

  role     SubjectSectionRole? @default(PRIMARY)
  isActive Boolean             @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([subjectSectionId, teacherId], map: "subject_section_teachers_ss_teacher_key")
  @@index([teacherId, updatedAt], map: "subject_section_teachers_teacher_updated_idx")
  // ⚠️ Partial unique index (in migration SQL, not expressible in Prisma):
  // UNIQUE ON (subject_section_id) WHERE is_deleted = false
  // — ensures only ONE active teacher per subject-section
  @@map("subject_section_teachers")
}

// =========================
// TIMETABLE (ADM-060/061)
// =========================

// جدول الحصص — واحد لكل شعبة + سنة + فصل
model Timetable {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  sectionId Int     @map("section_id")
  section   Section @relation(fields: [sectionId], references: [id])

  yearId Int  @map("year_id")
  year   Year @relation(fields: [yearId], references: [id])

  termId Int  @map("term_id")
  term   Term @relation(fields: [termId], references: [id])

  // MVP: حفظ = نشر — مستقبلاً يمكن دعم Draft/Published
  status         String    @default("PUBLISHED") @map("status")
  publishedAt    DateTime? @map("published_at")
  publishVersion Int       @default(1) @map("publish_version")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  slots TimetableSlot[]

  @@unique([sectionId, yearId, termId], map: "timetables_section_year_term_key")
  @@index([yearId, termId], map: "timetables_year_term_idx")
  @@map("timetables")
}

// حصة في الجدول — يوم + رقم حصة + مادة (المعلم يُحسم من ADM-052)
model TimetableSlot {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  timetableId Int       @map("timetable_id")
  timetable   Timetable @relation(fields: [timetableId], references: [id])

  weekday      Int // 0=سبت, 1=أحد, 2=اثنين, 3=ثلاثاء, 4=أربعاء, 5=خميس
  lessonNumber Int @map("lesson_number") // 1-8

  subjectSectionId Int?            @map("subject_section_id")
  subjectSection   SubjectSection? @relation(fields: [subjectSectionId], references: [id])

  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  isDeleted            Boolean               @default(false) @map("is_deleted")
  deletedAt            DateTime?             @map("deleted_at")
  lessonTimetableSlots LessonTimetableSlot[]

  @@unique([timetableId, weekday, lessonNumber], map: "timetable_slots_unique_slot_key")
  @@index([subjectSectionId], map: "timetable_slots_subject_section_idx")
  @@map("timetable_slots")
}

// =========================
// DEVICES & SESSIONS
// =========================

// أجهزة المستخدمين
model UserDevice {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  deviceFingerprint String     @map("device_fingerprint")
  pushToken         String?    @map("push_token")
  deviceType        DeviceType @map("device_type")

  lastSeenAt DateTime? @map("last_seen_at")
  isActive   Boolean   @default(true) @map("is_active")

  sessions AuthSession[]

  @@unique([userId, deviceFingerprint], map: "user_devices_user_device_fp_key")
  @@index([pushToken], map: "user_devices_push_token_idx")
  @@index([userId], map: "user_devices_user_id_idx")
  @@index([deviceFingerprint], map: "user_devices_device_fp_idx")
  @@map("user_devices")
}

// جلسات المصادقة
model AuthSession {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  schoolId  Int?    @map("school_id")
  school   School? @relation(fields: [schoolId], references: [id])

  deviceId Int?        @map("device_id")
  device   UserDevice? @relation(fields: [deviceId], references: [id])

  refreshTokenHash String @unique @map("refresh_token_hash")

  createdAt    DateTime      @default(now()) @map("created_at")
  lastSeenAt   DateTime?     @map("last_seen_at")
  expiresAt    DateTime      @map("expires_at")
  revokedAt    DateTime?     @map("revoked_at")
  revokeReason RevokeReason? @map("revoke_reason")

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([schoolId], map: "auth_sessions_school_id_idx")
  @@index([deviceId], map: "auth_sessions_device_id_idx")
  @@index([revokedAt], map: "auth_sessions_revoked_at_idx")
  @@map("auth_sessions")
}

// =========================
// MEDIA SYSTEM
// =========================

enum MediaKind {
  IMAGE
  AUDIO
}

enum MediaUploadStatus {
  INITIATED
  UPLOADING
  COMPLETED
  FAILED
  CANCELED
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

// سجل الوسائط الموحد (Metadata فقط — بدون تخزين الملف داخل DB)
model MediaAsset {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  schoolId  Int?    @map("school_id")
  ownerType String  @default("SCHOOL") @map("owner_type")
  school   School? @relation("SchoolMediaAssets", fields: [schoolId], references: [id])

  kind MediaKind

  storageKey  String? @map("storage_key") // مسار داخل VPS/S3
  originalUrl String? @map("original_url") // رابط النسخة الأصلية (اختياري)

  contentType String  @map("content_type") // مثل image/webp, audio/aac
  sizeBytes   BigInt  @default(0) @map("size_bytes")
  etag        String? // ETag للتحقق
  sha256      String? // Hash اختياري

  width       Int? // عرض الصورة
  height      Int? // ارتفاع الصورة
  durationSec Int? @map("duration_sec") // مدة الصوت بالثواني

  variantsJson     String? @map("variants_json") // JSON: variants metadata
  preferredVariant String? @map("preferred_variant")

  processingStatus ProcessingStatus @default(PENDING) @map("processing_status")
  rowVersion       Int              @default(0) @map("row_version")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  uploadSessions MediaUploadSession[]

  // Reverse relations from entities that reference this asset
  schoolsAsLogo          School[]            @relation("SchoolLogo")
  subjectsAsCover        Subject[]           @relation("SubjectCover")
  subjectDictsAsCover    SubjectDictionary[] @relation("SubjectDictCover")
  usersAsAvatar          User[]              @relation("UserAvatar")
  lessonTemplatesAsCover LessonTemplate[]    @relation("LessonTemplateCover")
  lessonContentsAsMedia  LessonContent[]     @relation("LessonContentMedia")

  // Question relations
  questionsAsImage            Question[]             @relation("QuestionImage")
  questionsAsAudio            Question[]             @relation("QuestionAudio")
  questionsAsExplanationImage Question[]             @relation("QuestionExplanationImage")
  questionsAsExplanationAudio Question[]             @relation("QuestionExplanationAudio")
  questionOptionsAsImage      QuestionOption[]       @relation("QuestionOptionImage")
  questionOptionsAsAudio      QuestionOption[]       @relation("QuestionOptionAudio")
  matchingPairsAsLeftImage    QuestionMatchingPair[] @relation("MatchingPairLeftImage")
  matchingPairsAsLeftAudio    QuestionMatchingPair[] @relation("MatchingPairLeftAudio")
  matchingPairsAsRightImage   QuestionMatchingPair[] @relation("MatchingPairRightImage")
  matchingPairsAsRightAudio   QuestionMatchingPair[] @relation("MatchingPairRightAudio")
  orderingItemsAsImage        QuestionOrderingItem[] @relation("OrderingItemImage")
  orderingItemsAsAudio        QuestionOrderingItem[] @relation("OrderingItemAudio")

  @@index([schoolId], map: "media_assets_school_id_idx")
  @@index([kind], map: "media_assets_kind_idx")
  @@index([ownerType], map: "media_assets_owner_type_idx")
  @@index([updatedAt], map: "media_assets_updated_at_idx")
  @@index([schoolId, updatedAt], map: "media_assets_school_updated_idx")
  @@map("media_assets")
}

// جلسات رفع الوسائط (Chunked Upload + Resume)
model MediaUploadSession {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  mediaAssetId Int        @map("media_asset_id")
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id])

  schoolId  Int?    @map("school_id")
  school    School? @relation("SchoolUploadSessions", fields: [schoolId], references: [id])
  ownerType String  @default("SCHOOL") @map("owner_type")

  uploaderUserId Int?  @map("uploader_user_id")
  uploader       User? @relation(fields: [uploaderUserId], references: [id])

  platformUserId    Int?          @map("platform_user_id")
  platformUploader  PlatformUser? @relation(fields: [platformUserId], references: [id])

  kind           MediaKind
  contentType    String    @map("content_type")
  totalSizeBytes BigInt?   @map("total_size_bytes")
  chunkSizeBytes Int       @map("chunk_size_bytes")

  status        MediaUploadStatus @default(INITIATED)
  bytesReceived BigInt            @default(0) @map("bytes_received")
  lastChunkAt   DateTime?         @map("last_chunk_at")

  tempStorageKey String? @map("temp_storage_key")

  requestedVariantsJson String?           @map("requested_variants_json")
  processingStatus      ProcessingStatus? @map("processing_status")

  attemptCount Int     @default(0) @map("attempt_count")
  lastError    String? @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  completedAt DateTime? @map("completed_at")
  expiresAt   DateTime  @map("expires_at")
  canceledAt  DateTime? @map("canceled_at")

  @@index([schoolId], map: "media_upload_sessions_school_id_idx")
  @@index([uploaderUserId, createdAt], map: "media_upload_sessions_uploader_idx")
  @@index([status, expiresAt], map: "media_upload_sessions_status_expires_idx")
  @@index([mediaAssetId], map: "media_upload_sessions_asset_id_idx")
  @@index([updatedAt], map: "media_upload_sessions_updated_at_idx")
  @@map("media_upload_sessions")
}

// ── الوحدات ─────────────────────────────────────────────────────────
model Unit {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  // ربط بالمادة: واحد فقط حسب owner_type
  subjectId            Int?               @map("subject_id")
  subject              Subject?           @relation(fields: [subjectId], references: [id])
  subjectDictionaryId  Int?               @map("subject_dictionary_id")
  subjectDictionary    SubjectDictionary? @relation(fields: [subjectDictionaryId], references: [id])

  ownerType String  @default("SCHOOL") @map("owner_type")
  schoolId  Int?    @map("school_id")
  school    School? @relation(fields: [schoolId], references: [id])

  title       String
  orderIndex  Int     @map("order_index")
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  lessonTemplates LessonTemplate[]

  @@unique([subjectId, orderIndex], map: "units_subject_order_idx")
  @@unique([subjectDictionaryId, orderIndex], map: "units_subject_dict_order_idx")
  @@index([subjectId], map: "units_subject_id_idx")
  @@index([subjectDictionaryId], map: "units_subject_dict_id_idx")
  @@index([ownerType], map: "units_owner_type_idx")
  @@map("units")
}

// ── قوالب الدروس ──────────────────────────────────────────────────────
model LessonTemplate {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  ownerType String  @default("SCHOOL") @map("owner_type")
  schoolId  Int?    @map("school_id")
  school    School? @relation(fields: [schoolId], references: [id])

  // ربط بالمادة: واحد فقط حسب owner_type
  subjectId            Int?               @map("subject_id")
  subject              Subject?           @relation(fields: [subjectId], references: [id])
  subjectDictionaryId  Int?               @map("subject_dictionary_id")
  subjectDictionary    SubjectDictionary? @relation(fields: [subjectDictionaryId], references: [id])

  unitId Int?  @map("unit_id")
  unit   Unit? @relation(fields: [unitId], references: [id])

  orderIndex Int    @default(1) @map("order_index")
  title      String
  status     String @default("DRAFT")

  coverMediaAssetId Int?        @map("cover_media_asset_id")
  coverMediaAsset   MediaAsset? @relation("LessonTemplateCover", fields: [coverMediaAssetId], references: [id])

  templateVersion  Int              @default(1) @map("template_version")
  sourceTemplateId Int?             @map("source_template_id")
  sourceTemplate   LessonTemplate?  @relation("LessonTemplateClone", fields: [sourceTemplateId], references: [id])
  clonedTemplates  LessonTemplate[] @relation("LessonTemplateClone")

  // من أنشأ القالب (حسب owner_type)
  createdByUserId         Int?           @map("created_by_user_id")
  createdByUser           User?          @relation("LessonTemplateCreator", fields: [createdByUserId], references: [id])
  createdByPlatformUserId Int?           @map("created_by_platform_user_id")
  createdByPlatformUser   PlatformUser?  @relation("PlatformLessonCreator", fields: [createdByPlatformUserId], references: [id])

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  contents  LessonContent[]
  questions Question[]
  lessons   Lesson[]

  @@unique([unitId, orderIndex], map: "lesson_templates_unit_order_idx")
  @@index([schoolId], map: "lesson_templates_school_id_idx")
  @@index([subjectId], map: "lesson_templates_subject_id_idx")
  @@index([subjectDictionaryId], map: "lesson_templates_subject_dict_id_idx")
  @@index([unitId], map: "lesson_templates_unit_id_idx")
  @@index([ownerType], map: "lesson_templates_owner_type_idx")
  @@index([coverMediaAssetId], map: "lesson_templates_cover_idx")
  @@index([sourceTemplateId], map: "lesson_templates_source_idx")
  @@index([updatedAt], map: "lesson_templates_updated_at_idx")
  @@map("lesson_templates")
}

// ── محتويات الدرس ─────────────────────────────────────────────────────
model LessonContent {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  templateId Int            @map("template_id")
  template   LessonTemplate @relation(fields: [templateId], references: [id])

  type  String // TEXT / IMAGE / AUDIO
  title String? // عنوان اختياري للكتلة (V10.1)

  mediaAssetId Int?        @map("media_asset_id")
  mediaAsset   MediaAsset? @relation("LessonContentMedia", fields: [mediaAssetId], references: [id])

  contentText String? @map("content_text")
  orderIndex  Int     @map("order_index")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([templateId, orderIndex], map: "lesson_contents_template_order_idx")
  @@index([templateId], map: "lesson_contents_template_id_idx")
  @@index([mediaAssetId], map: "lesson_contents_media_asset_id_idx")
  @@map("lesson_contents")
}

// ══════════════════════════════════════════════════════════════════════════
// ── الأسئلة (Questions & Options) ── المرحلة 3: TCH-090→101
// ══════════════════════════════════════════════════════════════════════════

// ── جدول الأسئلة الرئيسي ─────────────────────────────────────────────────
model Question {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  templateId Int            @map("template_id")
  template   LessonTemplate @relation(fields: [templateId], references: [id])

  type       String // MCQ / TRUE_FALSE / MATCHING / FILL / ORDERING
  orderIndex Int    @map("order_index")

  instructionText      String?     @map("instruction_text") // نص التعليمات (اختياري) — مثل: "أكمل الفراغات التالية"
  questionText         String?     @map("question_text") // النص التفاعلي (في FILL: يحتوي {{A}} placeholders)
  questionImageAssetId Int?        @map("question_image_asset_id")
  questionImageAsset   MediaAsset? @relation("QuestionImage", fields: [questionImageAssetId], references: [id])
  questionAudioAssetId Int?        @map("question_audio_asset_id")
  questionAudioAsset   MediaAsset? @relation("QuestionAudio", fields: [questionAudioAssetId], references: [id])

  score Float @default(1.0)

  explanationText         String?     @map("explanation_text")
  explanationImageAssetId Int?        @map("explanation_image_asset_id")
  explanationImageAsset   MediaAsset? @relation("QuestionExplanationImage", fields: [explanationImageAssetId], references: [id])
  explanationAudioAssetId Int?        @map("explanation_audio_asset_id")
  explanationAudioAsset   MediaAsset? @relation("QuestionExplanationAudio", fields: [explanationAudioAssetId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  options        QuestionOption[]
  matchingPairs  QuestionMatchingPair[]
  orderingItems  QuestionOrderingItem[]
  fillBlanks     QuestionFillBlank[]
  fillAnswers    QuestionFillAnswer[]
  studentAnswers StudentAnswer[]

  @@unique([templateId, orderIndex], map: "questions_template_order_idx")
  @@index([templateId], map: "questions_template_id_idx")
  @@index([questionImageAssetId], map: "questions_question_image_idx")
  @@index([questionAudioAssetId], map: "questions_question_audio_idx")
  @@index([explanationImageAssetId], map: "questions_explanation_image_idx")
  @@index([explanationAudioAssetId], map: "questions_explanation_audio_idx")
  @@map("questions")
}

// ── خيارات الأسئلة (MCQ + TRUE_FALSE) ────────────────────────────────────
model QuestionOption {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  questionId Int      @map("question_id")
  question   Question @relation(fields: [questionId], references: [id])

  optionText   String?     @map("option_text") // نص الخيار — في خيارات الصور يُستخدم كوصف نصي قصير (Label)
  imageAssetId Int?        @map("image_asset_id")
  imageAsset   MediaAsset? @relation("QuestionOptionImage", fields: [imageAssetId], references: [id])
  audioAssetId Int?        @map("audio_asset_id")
  audioAsset   MediaAsset? @relation("QuestionOptionAudio", fields: [audioAssetId], references: [id])

  isCorrect  Boolean @map("is_correct")
  orderIndex Int     @map("order_index")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@index([questionId], map: "question_options_question_id_idx")
  @@index([imageAssetId], map: "question_options_image_idx")
  @@index([audioAssetId], map: "question_options_audio_idx")
  @@map("question_options")
}

// ── أزواج المطابقة (MATCHING) ────────────────────────────────────────────
model QuestionMatchingPair {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  questionId Int      @map("question_id")
  question   Question @relation(fields: [questionId], references: [id])

  leftText         String?     @map("left_text")
  leftImageAssetId Int?        @map("left_image_asset_id")
  leftImageAsset   MediaAsset? @relation("MatchingPairLeftImage", fields: [leftImageAssetId], references: [id])
  leftAudioAssetId Int?        @map("left_audio_asset_id")
  leftAudioAsset   MediaAsset? @relation("MatchingPairLeftAudio", fields: [leftAudioAssetId], references: [id])

  rightText         String?     @map("right_text")
  rightImageAssetId Int?        @map("right_image_asset_id")
  rightImageAsset   MediaAsset? @relation("MatchingPairRightImage", fields: [rightImageAssetId], references: [id])
  rightAudioAssetId Int?        @map("right_audio_asset_id")
  rightAudioAsset   MediaAsset? @relation("MatchingPairRightAudio", fields: [rightAudioAssetId], references: [id])

  pairKey         String @map("pair_key")
  leftOrderIndex  Int?   @map("left_order_index")
  rightOrderIndex Int?   @map("right_order_index")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([questionId, pairKey], map: "matching_pairs_question_pair_key_idx")
  @@index([questionId], map: "matching_pairs_question_id_idx")
  @@index([leftImageAssetId], map: "matching_pairs_left_image_idx")
  @@index([leftAudioAssetId], map: "matching_pairs_left_audio_idx")
  @@index([rightImageAssetId], map: "matching_pairs_right_image_idx")
  @@index([rightAudioAssetId], map: "matching_pairs_right_audio_idx")
  @@map("question_matching_pairs")
}

// ── عناصر الترتيب (ORDERING) ─────────────────────────────────────────────
model QuestionOrderingItem {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  questionId Int      @map("question_id")
  question   Question @relation(fields: [questionId], references: [id])

  itemText     String?     @map("item_text")
  imageAssetId Int?        @map("image_asset_id")
  imageAsset   MediaAsset? @relation("OrderingItemImage", fields: [imageAssetId], references: [id])
  audioAssetId Int?        @map("audio_asset_id")
  audioAsset   MediaAsset? @relation("OrderingItemAudio", fields: [audioAssetId], references: [id])

  correctIndex Int @map("correct_index") // 1..N
  orderIndex   Int @map("order_index") // ترتيب العرض

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([questionId, correctIndex], map: "ordering_items_correct_idx")
  @@unique([questionId, orderIndex], map: "ordering_items_order_idx")
  @@index([questionId], map: "ordering_items_question_id_idx")
  @@index([imageAssetId], map: "ordering_items_image_idx")
  @@index([audioAssetId], map: "ordering_items_audio_idx")
  @@map("question_ordering_items")
}

// ── تعريف الفراغات (FILL) ────────────────────────────────────────────────
model QuestionFillBlank {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  questionId Int      @map("question_id")
  question   Question @relation(fields: [questionId], references: [id])

  blankKey    String  @map("blank_key") // "A", "B", ...
  orderIndex  Int     @map("order_index")
  placeholder String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([questionId, blankKey], map: "fill_blanks_question_key_idx")
  @@unique([questionId, orderIndex], map: "fill_blanks_question_order_idx")
  @@index([questionId], map: "fill_blanks_question_id_idx")
  @@map("question_fill_blanks")
}

// ── إجابات الفراغات (FILL) ───────────────────────────────────────────────
model QuestionFillAnswer {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  questionId Int      @map("question_id")
  question   Question @relation(fields: [questionId], references: [id])

  blankKey   String  @map("blank_key")
  answerText String  @map("answer_text")
  isPrimary  Boolean @default(false) @map("is_primary")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([questionId, blankKey, answerText], map: "fill_answers_unique_idx")
  @@index([questionId, blankKey], map: "fill_answers_question_key_idx")
  @@map("question_fill_answers")
}

// ══════════════════════════════════════════════════════════════════════════
// ── النشر والتمرير (Phase 4: TCH-070/013/080/081) ──────────────────────
// ══════════════════════════════════════════════════════════════════════════

// ── الدرس المنشور (نسخة موجهة للطلاب) ─────────────────────────────────
model Lesson {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  templateId Int            @map("template_id")
  template   LessonTemplate @relation(fields: [templateId], references: [id])

  schoolId Int    @map("school_id")
  school   School @relation(fields: [schoolId], references: [id])

  teacherId Int     @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [userId])

  subjectId Int     @map("subject_id")
  subject   Subject @relation(fields: [subjectId], references: [id])

  yearId Int  @map("year_id")
  year   Year @relation(fields: [yearId], references: [id])

  termId Int  @map("term_id")
  term   Term @relation(fields: [termId], references: [id])

  // الحالة: READY → PUBLISHED → DELIVERED → ARCHIVED
  status String @default("READY")

  // طريقة التمرير: OPEN / SCHEDULED / MANUAL_APPROVAL / MANUAL_OVERRIDE
  deliveryMethod String? @map("delivery_method")

  // نوع الربط: SLOT_COVERAGE / ADDITIONAL
  linkType String @default("ADDITIONAL") @map("link_type")

  publishedAt DateTime? @map("published_at")
  deliveredAt DateTime? @map("delivered_at")

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  targets         LessonTarget[]
  timetableSlots  LessonTimetableSlot[]
  deliveryLogs    LessonDeliveryLog[]
  studentProgress StudentLessonProgress[]
  studentResults  StudentLessonResult[]

  @@index([templateId], map: "lessons_template_id_idx")
  @@index([schoolId], map: "lessons_school_id_idx")
  @@index([teacherId], map: "lessons_teacher_id_idx")
  @@index([subjectId], map: "lessons_subject_id_idx")
  @@index([yearId, termId], map: "lessons_year_term_idx")
  @@index([status], map: "lessons_status_idx")
  @@index([updatedAt], map: "lessons_updated_at_idx")
  @@map("lessons")
}

// ── استهداف الشُعب ──────────────────────────────────────────────────────
model LessonTarget {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  lessonId Int    @map("lesson_id")
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  sectionId Int     @map("section_id")
  section   Section @relation(fields: [sectionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([lessonId, sectionId], map: "lesson_targets_lesson_section_key")
  @@index([sectionId], map: "lesson_targets_section_id_idx")
  @@map("lesson_targets")
}

// ── ربط الدرس بحصص الجدول ───────────────────────────────────────────────
model LessonTimetableSlot {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  lessonId Int    @map("lesson_id")
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  timetableSlotId Int           @map("timetable_slot_id")
  timetableSlot   TimetableSlot @relation(fields: [timetableSlotId], references: [id])

  // تاريخ بداية الأسبوع المحدد
  weekDate DateTime? @map("week_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([lessonId, timetableSlotId, weekDate], map: "lesson_timetable_slots_unique_key")
  @@index([timetableSlotId], map: "lesson_timetable_slots_slot_idx")
  @@map("lesson_timetable_slots")
}

// ── سجل التمرير ─────────────────────────────────────────────────────────
model LessonDeliveryLog {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  lessonId Int    @map("lesson_id")
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  actorUserId Int  @map("actor_user_id")
  actorUser   User @relation("LessonDeliveryActor", fields: [actorUserId], references: [id])

  // PUBLISH / DELIVER / OVERRIDE_DELIVER / ADD_TARGETS
  action       String
  policyAtTime String? @map("policy_at_time")
  details      String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([lessonId], map: "lesson_delivery_logs_lesson_idx")
  @@index([actorUserId], map: "lesson_delivery_logs_actor_idx")
  @@map("lesson_delivery_logs")
}

// ══════════════════════════════════════════════════════════════════════════
// ── تقدّم الطالب والإجابات (STD-050 → STD-071) ──────────────────────────
// ══════════════════════════════════════════════════════════════════════════

// ── حالة تقدّم الطالب في الدرس ──────────────────────────────────────────
model StudentLessonProgress {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [userId])

  lessonId Int    @map("lesson_id")
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  status       String // NOT_STARTED / IN_PROGRESS / COMPLETED
  lastPosition String? @map("last_position") @db.Text // JSON

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  rowVersion Int       @default(0) @map("row_version")
  isDeleted  Boolean   @default(false) @map("is_deleted")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([studentId, lessonId], map: "student_lesson_progress_unique")
  @@index([studentId], map: "student_lesson_progress_student_idx")
  @@index([lessonId], map: "student_lesson_progress_lesson_idx")
  @@map("student_lesson_progress")
}

// ── نتائج الطالب (لكل محاولة) ────────────────────────────────────────────
model StudentLessonResult {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [userId])

  lessonId Int    @map("lesson_id")
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  totalQuestions   Int      @map("total_questions")
  correctQuestions Int      @map("correct_questions")
  totalPoints      Float    @map("total_points")
  earnedPoints     Float    @map("earned_points")
  percent          Float
  gradeLabel       String   @map("grade_label")
  calculatedAt     DateTime @map("calculated_at")
  version          Int      @default(1)

  answers StudentAnswer[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@index([studentId, lessonId], map: "student_lesson_results_student_lesson_idx")
  @@map("student_lesson_results")
}

// ── إجابات الطالب (unique per student+question — الأخيرة تطغى) ───────────
model StudentAnswer {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [userId])

  questionId Int      @map("question_id")
  question   Question @relation(fields: [questionId], references: [id])

  resultId Int?                 @map("result_id")
  result   StudentLessonResult? @relation(fields: [resultId], references: [id])

  answerValue  String   @map("answer_value") @db.Text // JSON
  correctness  String // CORRECT / WRONG
  isCorrect    Boolean? @map("is_correct")
  scoreAwarded Float    @map("score_awarded")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  rowVersion Int       @default(0) @map("row_version")
  isDeleted  Boolean   @default(false) @map("is_deleted")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([studentId, questionId], map: "student_answers_student_question_unique")
  @@index([resultId], map: "student_answers_result_idx")
  @@index([updatedAt], map: "student_answers_updated_idx")
  @@map("student_answers")
}

// =========================
// PLATFORM CONTENT SYSTEM
// =========================

// مستخدمو منصة المحتوى (مدير المنصة + معلمو المنصة)
model PlatformUser {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  username     String  @unique
  email        String?  @unique
  passwordHash String  @map("password_hash")
  name         String
  displayName  String? @map("display_name")
  phone        String?

  role     PlatformRole @default(PLATFORM_TEACHER)
  isActive Boolean      @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  assignedSubjects      PlatformUserSubject[]
  createdLessonTemplates LessonTemplate[]      @relation("PlatformLessonCreator")
  uploadSessions         MediaUploadSession[]

  @@map("platform_users")
}

// إسناد المواد الرسمية لمعلمي المنصة
model PlatformUserSubject {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  platformUserId Int          @map("platform_user_id")
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id])

  subjectDictionaryId Int               @map("subject_dictionary_id")
  subjectDictionary   SubjectDictionary @relation(fields: [subjectDictionaryId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  @@unique([platformUserId, subjectDictionaryId], map: "platform_user_subjects_user_subject_key")
  @@index([platformUserId], map: "platform_user_subjects_user_id_idx")
  @@index([subjectDictionaryId], map: "platform_user_subjects_subject_dict_idx")
  @@map("platform_user_subjects")
}

// سجل المراجعة الموحد
model AuditLog {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  actorUserId Int  @map("actor_user_id")
  schoolId    Int? @map("school_id")

  entityType String @map("entity_type")
  entityId   String @map("entity_id")
  action     String

  oldValues Json? @map("old_values")
  newValues Json? @map("new_values")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorUserId, createdAt], map: "audit_logs_actor_created_idx")
  @@index([entityType, entityId], map: "audit_logs_entity_idx")
  @@index([action], map: "audit_logs_action_idx")
  @@index([schoolId], map: "audit_logs_school_idx")
  @@index([createdAt], map: "audit_logs_created_at_idx")
  @@map("audit_logs")
}
